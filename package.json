{
  "name": "fanoron-telo-ia",
  "version": "1.0.0",
  "private": true,
  "description": "Fanoron-telo (jeu malgache 3x3) avec IA Minimax / Alpha-Bêta. Projet Algorithmique Avancée — ISPM.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c yellow,cyan \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "start": "node backend/src/server.js",
    "test": "npm test --workspace backend",
    "benchmark": "npm run benchmark --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
